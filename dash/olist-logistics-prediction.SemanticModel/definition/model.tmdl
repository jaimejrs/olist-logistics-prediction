model Model
	culture: pt-BR
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: pt-BR
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_ProTooling = ["DevMode"]

annotation PBI_QueryOrder = ["PG_Server","PG_Database","fact_orders","dim_date","dim_geografia","dim_categoria","dim_pagamento","dim_cliente"]

ref table dim_date
ref table fact_orders
ref table _Medidas
ref table dim_geografia
ref table dim_categoria
ref table dim_pagamento
ref table dim_cliente

ref cultureInfo pt-BR

